# ── Okta Configuration ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# See the notebook's Okta Setup Reference section for setup instructions.

OKTA_DOMAIN=your-domain.okta.com
OKTA_AUTH_SERVER_ID=your-auth-server-id

# Gateway App (Gateway -> MCP Server) - API Service Integration
OKTA_GATEWAY_CLIENT_ID=your-gateway-client-id
OKTA_GATEWAY_CLIENT_SECRET=your-gateway-client-secret
OKTA_MCP_SCOPE=mcp:invoke

# Agent App (Agent -> Gateway) - API Service Integration
OKTA_AGENT_CLIENT_ID=your-agent-client-id
OKTA_AGENT_CLIENT_SECRET=your-agent-client-secret
OKTA_AGENT_SCOPE=gateway:invoke

# User App (User -> Agent) - Web Application with Authorization Code grant
# Add http://localhost:8080/callback as Sign-in redirect URI in Okta
OKTA_USER_CLIENT_ID=your-user-client-id
OKTA_USER_CLIENT_SECRET=your-user-client-secret
OKTA_USER_SCOPE=agent:invoke openid email groups

# Demo Users (for RBAC testing - emails used as login_hint)
OKTA_USER_ALICE_EMAIL=alice@example.com
OKTA_USER_BOB_EMAIL=bob@example.com

# ── AWS Configuration ──────────────────────────────────────────────────────────
# AWS credentials should be set via AWS CLI or environment variables.
# For temporary credentials, fill in the values below.

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token
AWS_REGION=us-west-2
